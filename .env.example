# Copy to .env and fill in your values — never commit .env

# Local DB password (defaults come from .laneconductor.json)
DB_PASSWORD=postgres

# Cloud DB password — required when sync_mode is "dual" or "remote"
# CLOUD_DB_HOST=db.xxxx.supabase.co
# CLOUD_DB_PORT=5432
# CLOUD_DB_NAME=postgres
# CLOUD_DB_USER=postgres
CLOUD_DB_PASSWORD=

# GCP / Firebase project ID — used by scripts/migrate-prod.sh
# GCP_PROJECT_ID=your-firebase-project-id

# UI / API ports
# API_PORT=8091
