{
  "global": {
    "total_parallel_limit": 3
  },
  "defaults": {
    "parallel_limit": 1,
    "max_retries": 1
  },
  "lanes": {
    "plan": {
      "parallel_limit": 1,
      "max_retries": 1,
      "on_success": "plan:success",
      "on_failure": "backlog"
    },
    "implement": {
      "parallel_limit": 1,
      "max_retries": 3,
      "on_success": "review:queue",
      "on_failure": "implement:failure"
    },
    "review": {
      "parallel_limit": 1,
      "max_retries": 1,
      "on_success": "quality-gate:queue",
      "on_failure": "implement:queue"
    },
    "quality-gate": {
      "parallel_limit": 1,
      "max_retries": 1,
      "on_success": "done:success",
      "on_failure": "plan:queue"
    },
    "done": {
      "parallel_limit": 1
    }
  }
}
